---
import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { shoes, brands, categories } from '../db/schema';
import { eq } from 'drizzle-orm';
import type { InferSelectModel } from 'drizzle-orm';

type Shoe = InferSelectModel<typeof shoes>;
type Brand = InferSelectModel<typeof brands>;
type Category = InferSelectModel<typeof categories>;

interface FormattedShoe extends Omit<Shoe, 'sizes' | 'images'> {
  brand: Brand | null;
  category: Category | null;
  sizes: string[];
  images: string[];
}

let featuredShoes: Array<{ shoe: Shoe; brand: Brand | null; category: Category | null }> = [];
let allCategories: Category[] = [];
let allBrands: Brand[] = [];
let formattedShoes: FormattedShoe[] = [];

try {
  // Get featured products
  featuredShoes = await db
    .select({
      shoe: shoes,
      brand: brands,
      category: categories,
    })
    .from(shoes)
    .leftJoin(brands, eq(shoes.brand_id, brands.id))
    .leftJoin(categories, eq(shoes.category_id, categories.id))
    .where(eq(shoes.is_featured, 1))
    .limit(4);

  // Get all categories
  allCategories = await db.select().from(categories);

  // Get all brands
  allBrands = await db.select().from(brands);

  formattedShoes = featuredShoes.map(({ shoe, brand, category }) => ({
    ...shoe,
    brand,
    category,
    sizes: JSON.parse(shoe.sizes),
    images: shoe.images ? JSON.parse(shoe.images) : [],
  }));
} catch (error) {
  console.error('❌ [Homepage] Database error:', error);
}
---

<Layout title="AV Parfums - Fragancias de Lujo en Guatemala">
  <!-- Hero Section -->
  <section class="relative bg-black text-white overflow-hidden" aria-label="Banner principal">
    <div class="absolute inset-0">
      <img
        src="/banner-hero.png"
        alt=""
        role="presentation"
        width="1920"
        height="800"
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <!-- Content -->
    <div class="relative container mx-auto px-4 py-24 md:py-32">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Spacer to maintain height -->
        <div class="mb-32 md:mb-40"></div>
        
        <p class="text-xl md:text-2xl text-gray-300 mb-10 leading-relaxed max-w-2xl mx-auto font-light">
          Colección exclusiva de perfumes de las mejores marcas internacionales. Elegancia y sofisticación en cada fragancia.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/catalog"
            class="inline-block bg-[#D4AF37] text-black px-10 py-4 rounded font-semibold text-lg hover:bg-[#C5A028] transition shadow-lg hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-[#D4AF37] focus:ring-offset-2 focus:ring-offset-black"
          >
            Explorar Catálogo
          </a>
          <a
            href="/catalog?featured=true"
            class="inline-block border-2 border-white text-white px-10 py-4 rounded font-semibold text-lg hover:bg-white hover:text-black transition focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-black"
          >
            Ver Destacados
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  {allCategories.length > 0 && (
    <section class="py-20 bg-gray-50" aria-labelledby="categories-heading">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] font-medium tracking-[0.2em] uppercase text-sm mb-3">Colecciones</p>
          <h2 id="categories-heading" class="font-display text-4xl md:text-5xl font-bold">Explora por Categoría</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {allCategories.map((category) => {
            // Map category names to Spanish
            const categoryNames: { [key: string]: string } = {
              "Men's": "Fragancias para Hombres",
              "Women's": "Fragancias para Mujeres"
            };
            const displayName = categoryNames[category.name] || category.name;
            
            return (
              <a
                href={`/catalog?category=${category.slug}`}
                class="group relative overflow-hidden rounded-lg bg-white hover:shadow-2xl transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#D4AF37] focus:ring-offset-2 block border border-gray-200"
                aria-label={`Ver productos de ${displayName}`}
              >
                <div class="p-12 text-center">
                  <div class="mb-4 flex justify-center">
                    {category.slug === 'mens' ? (
                      <svg class="w-16 h-16 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                      </svg>
                    ) : (
                      <svg class="w-16 h-16 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />
                      </svg>
                    )}
                  </div>
                  <h3 class="font-display text-3xl font-bold mb-2 group-hover:text-[#D4AF37] transition">
                    {displayName}
                  </h3>
                  <p class="text-gray-600 mb-4">{category.description}</p>
                  <span class="inline-flex items-center text-[#D4AF37] font-semibold group-hover:gap-2 transition-all">
                    Explorar
                    <svg class="w-5 h-5 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Products -->
  {formattedShoes.length > 0 && (
    <section class="py-20 bg-white" aria-labelledby="featured-heading">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] font-medium tracking-[0.2em] uppercase text-sm mb-3">Selección Especial</p>
          <h2 id="featured-heading" class="font-display text-4xl md:text-5xl font-bold mb-4">Fragancias Destacadas</h2>
          <a href="/catalog?featured=true" class="text-[#D4AF37] font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded px-2 py-1 inline-flex items-center gap-1">
            Ver Todas
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
          {formattedShoes.map((shoe) => (
            <article class="flex">
              <a
                href={`/catalog/${shoe.slug}`}
                class="group bg-white rounded-lg overflow-hidden border border-gray-200 hover:border-[#D4AF37] hover:shadow-xl transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#D4AF37] focus:ring-offset-2 flex flex-col w-full"
                aria-label={`Ver detalles de ${shoe.name}`}
              >
                <div class="aspect-square overflow-hidden bg-gray-50 flex-shrink-0">
                  <img
                    src={shoe.image_url}
                    alt={shoe.name}
                    width="400"
                    height="400"
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                  />
                </div>
                <div class="p-5 flex flex-col flex-grow">
                  <p class="text-[#D4AF37] text-xs font-semibold mb-2 uppercase tracking-wider">{shoe.brand?.name}</p>
                  <h3 class="font-semibold text-lg mb-3 line-clamp-2 min-h-[3.5rem] group-hover:text-[#D4AF37] transition">{shoe.name}</h3>
                  <div class="mt-auto">
                    <p class="text-2xl font-bold" aria-label={`Precio: ${shoe.price.toFixed(2)} quetzales`}>Q{shoe.price.toFixed(2)}</p>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Brands Section -->
  {allBrands.length > 0 && (
    <section class="py-20 bg-black text-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] font-medium tracking-[0.2em] uppercase text-sm mb-3">Nuestras Marcas</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold">Calidad Internacional</h2>
        </div>
        <div class="flex flex-wrap justify-center items-center gap-12">
          {allBrands.map((brand) => (
            <a
              href={`/catalog?brand=${brand.slug}`}
              class="font-display text-3xl font-bold hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded px-4 py-2"
            >
              {brand.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why Choose Us -->
  <section class="py-20 bg-gray-50" aria-labelledby="benefits-heading">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-[#D4AF37] font-medium tracking-[0.2em] uppercase text-sm mb-3">Experiencia Premium</p>
        <h2 id="benefits-heading" class="font-display text-4xl md:text-5xl font-bold">¿Por Qué Elegirnos?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <article class="text-center p-6">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <div class="w-16 h-16 bg-[#D4AF37] rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            </div>
          </div>
          <h3 class="font-semibold text-xl mb-2">Envío Gratis</h3>
          <p class="text-gray-600">En compras mayores a Q500</p>
        </article>
        <article class="text-center p-6">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <div class="w-16 h-16 bg-[#D4AF37] rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
              </svg>
            </div>
          </div>
          <h3 class="font-semibold text-xl mb-2">100% Originales</h3>
          <p class="text-gray-600">Fragancias auténticas garantizadas</p>
        </article>
        <article class="text-center p-6">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <div class="w-16 h-16 bg-[#D4AF37] rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
            </div>
          </div>
          <h3 class="font-semibold text-xl mb-2">Pago Seguro</h3>
          <p class="text-gray-600">Transacciones protegidas</p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-20 bg-gradient-to-r from-black via-gray-900 to-black text-white">
    <div class="container mx-auto px-4 text-center">
      <p class="text-[#D4AF37] font-medium tracking-[0.2em] uppercase text-sm mb-4">Oferta Especial</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Descubre tu fragancia ideal</h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">Explora nuestra colección exclusiva de perfumes de lujo</p>
      <a
        href="/catalog"
        class="inline-block bg-[#D4AF37] text-black px-10 py-4 rounded font-semibold text-lg hover:bg-[#C5A028] transition shadow-xl"
      >
        Ver Catálogo Completo
      </a>
    </div>
  </section>
</Layout>
