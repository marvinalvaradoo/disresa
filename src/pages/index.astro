---
import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { shoes, brands, categories } from '../db/schema';
import { eq } from 'drizzle-orm';

let featuredShoes = [];
let allCategories = [];
let allBrands = [];
let formattedShoes = [];

try {
  // Get featured products
  featuredShoes = await db
    .select({
      shoe: shoes,
      brand: brands,
      category: categories,
    })
    .from(shoes)
    .leftJoin(brands, eq(shoes.brand_id, brands.id))
    .leftJoin(categories, eq(shoes.category_id, categories.id))
    .where(eq(shoes.is_featured, 1))
    .limit(4);

  // Get all categories
  allCategories = await db.select().from(categories);

  // Get all brands
  allBrands = await db.select().from(brands);

  formattedShoes = featuredShoes.map(({ shoe, brand, category }) => ({
    ...shoe,
    brand,
    category,
    sizes: JSON.parse(shoe.sizes),
    images: shoe.images ? JSON.parse(shoe.images) : [],
  }));
} catch (error) {
  console.error('Database error:', error);
  // Continue rendering with empty data
}
---

<Layout title="Disresa - Tu tienda de zapatos de confianza">
  <!-- Hero Section -->
  <section class="relative bg-[#0061bd] text-white overflow-hidden" aria-label="Banner principal">
    <!-- Background Image with explicit dimensions to prevent CLS -->
    <div class="absolute inset-0" style="min-height: 500px;">
      <img
        src="/hero-banner.jpg"
        alt=""
        role="presentation"
        width="1920"
        height="800"
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover opacity-60"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-transparent"></div>
    </div>
    
    <!-- Content -->
    <div class="relative container mx-auto px-4 py-20 md:py-32">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-6 drop-shadow-lg">
          Da el paso<br />a la excelencia
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 mb-8 leading-relaxed drop-shadow-md">
          Descubre nuestra colección exclusiva de zapatos de las mejores marcas. Calidad, estilo y comodidad en cada paso.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/catalog"
            class="inline-block bg-[#fef24e] text-[#0061bd] px-8 py-4 rounded-lg font-black text-lg hover:bg-[#fdfad7] transition text-center shadow-xl hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-[#fef24e] focus:ring-offset-2 focus:ring-offset-black"
          >
            Comprar Ahora
          </a>
          <a
            href="/catalog"
            class="inline-block border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white hover:text-[#0061bd] transition text-center backdrop-blur-sm focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-black"
          >
            Ver Catálogo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  {allCategories.length > 0 && (
    <section class="py-16 bg-white" aria-labelledby="categories-heading">
      <div class="container mx-auto px-4">
        <h2 id="categories-heading" class="text-4xl font-black text-center mb-12">Explora por Categoría</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {allCategories.map((category) => {
            const categoryImages: { [key: string]: string } = {
              'mujer': '/womens-banner.jpg',
              'hombre': '/skechers-men-banner.webp'
            };
            const imageUrl = categoryImages[category.slug] || '';
            
            return (
              <a
                href={`/catalog?category=${category.slug}`}
                class="group relative overflow-hidden rounded-lg bg-black hover:shadow-xl transition focus:outline-none focus:ring-2 focus:ring-[#0061bd] focus:ring-offset-2 block"
                aria-label={`Ver productos de ${category.name}`}
                style="min-height: 400px; display: flex; align-items: center; justify-content: center;"
              >
                {imageUrl && (
                  <img
                    src={imageUrl}
                    alt={`Categoría ${category.name}`}
                    width="800"
                    height="450"
                    loading="lazy"
                    class="w-full h-full object-contain group-hover:scale-105 transition duration-300"
                    style="max-height: 400px;"
                  />
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10 pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                  <h3 class="text-white text-3xl font-bold  transition">
                    {category.name}
                  </h3>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Products -->
  {formattedShoes.length > 0 && (
    <section class="py-16 bg-gray-50" aria-labelledby="featured-heading">
      <div class="container mx-auto px-4">
        <div class="flex justify-between items-center mb-12">
          <h2 id="featured-heading" class="text-4xl font-black">Productos Destacados</h2>
          <a href="/catalog?featured=true" class="text-[#0061bd] font-bold hover:underline focus:outline-none focus:ring-2 focus:ring-[#0061bd] rounded px-2 py-1">
            Ver Todos →
          </a>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {formattedShoes.map((shoe) => (
            <article class="flex">
              <a
                href={`/catalog/${shoe.slug}`}
                class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition focus:outline-none focus:ring-2 focus:ring-[#0061bd] focus:ring-offset-2 flex flex-col w-full"
                aria-label={`Ver detalles de ${shoe.name}`}
              >
                <div class="aspect-square overflow-hidden bg-gray-100 flex-shrink-0">
                  <img
                    src={shoe.image_url}
                    alt={shoe.name}
                    width="400"
                    height="400"
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-110 transition duration-300"
                  />
                </div>
                <div class="p-4 flex flex-col flex-grow">
                  <p class="text-[#0061bd] text-sm font-bold mb-1">{shoe.brand?.name}</p>
                  <h3 class="font-bold text-lg mb-2 line-clamp-2 min-h-[3.5rem]">{shoe.name}</h3>
                  <div class="flex items-center gap-2 mb-3 flex-wrap min-h-[2rem]" role="list" aria-label="Tallas disponibles">
                    {shoe.sizes.slice(0, 4).map((size: string) => (
                      <span class="text-xs bg-gray-100 px-2 py-1 rounded" role="listitem">{size}</span>
                    ))}
                    {shoe.sizes.length > 4 && (
                      <span class="text-xs text-gray-500" aria-label={`${shoe.sizes.length - 4} tallas más disponibles`}>+{shoe.sizes.length - 4}</span>
                    )}
                  </div>
                  <div class="flex items-center gap-2 mt-auto">
                    <p class="text-2xl font-black" aria-label={`Precio: ${shoe.price.toFixed(2)} quetzales`}>Q{shoe.price.toFixed(2)}</p>
                    {shoe.original_price && shoe.original_price > shoe.price && (
                      <p class="text-gray-400 line-through" aria-label={`Precio original: ${shoe.original_price.toFixed(2)} quetzales`}>Q{shoe.original_price.toFixed(2)}</p>
                    )}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Brands Strip -->
  {allBrands.length > 0 && (
    <section class="py-12 bg-[#0061bd] text-white">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-black text-center mb-8">Marcas Destacadas</h2>
        <div class="flex flex-wrap justify-center items-center gap-8">
          {allBrands.map((brand) => (
            <a
              href={`/catalog?brand=${brand.slug}`}
              class="text-2xl font-bold hover:text-[#fef24e] transition focus:outline-none focus:ring-2 focus:ring-[#fef24e] rounded px-2 py-1"
            >
              {brand.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why Choose Us -->
  <section class="py-16 bg-white" aria-labelledby="benefits-heading">
    <div class="container mx-auto px-4">
      <h2 id="benefits-heading" class="text-4xl font-black text-center mb-12">¿Por Qué Elegirnos?</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <article class="text-center">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <svg class="w-16 h-16 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Envío Gratis</h3>
          <p class="text-gray-600">En compras mayores a Q500</p>
        </article>
        <article class="text-center">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <svg class="w-16 h-16 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Calidad Garantizada</h3>
          <p class="text-gray-600">Productos 100% originales</p>
        </article>
        <article class="text-center">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <svg class="w-16 h-16 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Devoluciones Fáciles</h3>
          <p class="text-gray-600">30 días para cambios</p>
        </article>
        <article class="text-center">
          <div class="flex justify-center mb-4" aria-hidden="true">
            <svg class="w-16 h-16 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Pago Seguro</h3>
          <p class="text-gray-600">Transacciones protegidas</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Promotional Banner -->
  <section class="py-16 bg-gradient-to-r from-[#0061bd] to-[#004a94] text-white">
    <div class="container mx-auto px-4 text-center">
      <p class="text-[#fef24e] font-black mb-2 text-lg">OFERTA ESPECIAL</p>
      <h2 class="text-4xl md:text-5xl font-black mb-4">Hasta 40% de descuento</h2>
      <p class="text-xl text-gray-100 mb-8">En estilos seleccionados. Oferta por tiempo limitado.</p>
      <a
        href="/catalog"
        class="inline-block bg-[#fef24e] text-[#0061bd] px-8 py-4 rounded-lg font-black text-lg hover:bg-[#fdfad7] transition shadow-xl"
      >
        Ver Ofertas
      </a>
    </div>
  </section>
</Layout>
