---
import Layout from '../layouts/Layout.astro';

const envCheck = {
  NODE_ENV: process.env.NODE_ENV || 'not set',
  TURSO_DATABASE_URL: process.env.TURSO_DATABASE_URL ? 'SET (length: ' + process.env.TURSO_DATABASE_URL.length + ')' : 'NOT SET',
  TURSO_AUTH_TOKEN: process.env.TURSO_AUTH_TOKEN ? 'SET (length: ' + process.env.TURSO_AUTH_TOKEN.length + ')' : 'NOT SET',
};
---

<Layout title="Test Page - Disresa">
  <div class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-black mb-8">🔍 Diagnóstico de Netlify</h1>
    
    <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
      <h2 class="text-2xl font-bold mb-4">Variables de Entorno</h2>
      <pre class="bg-gray-100 p-4 rounded overflow-x-auto">{JSON.stringify(envCheck, null, 2)}</pre>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
      <h2 class="text-2xl font-bold mb-4">Estado del Servidor</h2>
      <p class="text-green-600 font-bold">✅ El servidor Astro está funcionando correctamente</p>
      <p class="text-gray-600 mt-2">Si ves esta página, significa que Netlify está sirviendo contenido correctamente.</p>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6">
      <h2 class="text-2xl font-bold mb-4">Próximos Pasos</h2>
      
      {envCheck.TURSO_AUTH_TOKEN === 'NOT SET' ? (
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4">
          <h3 class="text-red-800 font-bold mb-2">⚠️ Falta TURSO_AUTH_TOKEN</h3>
          <p class="text-red-700 mb-2">Para que el sitio funcione en producción, necesitas:</p>
          <ol class="list-decimal list-inside space-y-2 text-red-700 ml-4">
            <li>Crear una base de datos Turso: <code class="bg-red-100 px-2 py-1 rounded">turso db create disresa-prod</code></li>
            <li>Obtener el token: <code class="bg-red-100 px-2 py-1 rounded">turso db tokens create disresa-prod</code></li>
            <li>Ir a <a href="https://app.netlify.com" target="_blank" class="underline font-bold">Netlify Dashboard</a></li>
            <li>Site configuration → Environment variables</li>
            <li>Agregar TURSO_AUTH_TOKEN con el token generado</li>
            <li>Redeploy el sitio</li>
          </ol>
        </div>
      ) : (
        <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-4">
          <h3 class="text-green-800 font-bold mb-2">✅ Variables configuradas correctamente</h3>
          <p class="text-green-700">Todas las variables de entorno están configuradas.</p>
        </div>
      )}
      
      <ol class="list-decimal list-inside space-y-2 mt-4">
        <li>Verifica que las variables de entorno arriba estén configuradas</li>
        <li>Visita <a href="/api/health" class="text-blue-600 underline">/api/health</a> para verificar la conexión a la base de datos</li>
        <li>Si todo está bien, visita la <a href="/" class="text-blue-600 underline">página de inicio</a></li>
      </ol>
    </div>

    <div class="mt-8">
      <a href="/" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700">
        Intentar ir a Home
      </a>
    </div>
  </div>
</Layout>
