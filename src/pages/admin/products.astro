---
import { getSession } from '../../lib/auth';
import { db } from '../../db';
import { shoes, brands, categories } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import '../../styles/global.css';

// Check authentication
const user = await getSession(Astro.cookies);
if (!user) {
  return Astro.redirect('/login');
}

// Get all products with brands and categories
const allProducts = await db
  .select({
    shoe: shoes,
    brand: brands,
    category: categories,
  })
  .from(shoes)
  .leftJoin(brands, eq(shoes.brand_id, brands.id))
  .leftJoin(categories, eq(shoes.category_id, categories.id))
  .orderBy(desc(shoes.created_at));

const formattedProducts = allProducts.map(({ shoe, brand, category }) => ({
  ...shoe,
  brand,
  category,
  sizes: JSON.parse(shoe.sizes),
}));

// Get all brands and categories for the form
const allBrands = await db.select().from(brands);
const allCategories = await db.select().from(categories);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Productos - Admin AV Parfums</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-gray-50 font-sans">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-black text-white flex flex-col">
      <div class="p-6">
        <img src="/new-logo.png" alt="AV Parfums" class="h-10 mb-2 brightness-0 invert" />
        <p class="text-sm text-gray-400">Panel de Administración</p>
      </div>

      <nav class="flex-1 px-4">
        <a href="/admin" class="flex items-center px-4 py-3 hover:bg-gray-800 rounded-lg mb-2 transition">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
          Dashboard
        </a>
        <a href="/admin/products" class="flex items-center px-4 py-3 bg-[#D4AF37] text-black rounded-lg mb-2 font-bold">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
          </svg>
          Productos
        </a>
        <a href="/admin/invoices" class="flex items-center px-4 py-3 hover:bg-gray-800 rounded-lg mb-2 transition">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          Facturas
        </a>
        <a href="/admin/customers" class="flex items-center px-4 py-3 hover:bg-gray-800 rounded-lg mb-2 transition">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
          Clientes
        </a>
      </nav>

      <div class="p-4 border-t border-gray-800">
        <div class="mb-4">
          <p class="text-sm text-gray-400">Sesión iniciada como:</p>
          <p class="font-semibold">{user.name || user.email}</p>
          <p class="text-xs text-[#D4AF37]">{user.role}</p>
        </div>
        <form action="/api/auth/logout" method="POST">
          <button
            type="submit"
            class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg transition font-semibold"
          >
            Cerrar Sesión
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto">
      <div class="p-8">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
          <div>
            <h1 class="text-4xl font-bold mb-2">Fragancias</h1>
            <p class="text-gray-600">{formattedProducts.length} fragancias en total</p>
          </div>
          <button
            id="openModalBtn"
            class="bg-[#D4AF37] text-black px-6 py-3 rounded-lg font-semibold hover:bg-[#C5A028] transition shadow-lg flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nueva Fragancia
          </button>
        </div>

        <!-- Products Table -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Imagen</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Nombre</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Marca</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Categoría</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Precio</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Stock</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Estado</th>
                  <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                {formattedProducts.map((product) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                      <img
                        src={product.image_url}
                        alt={product.name}
                        class="w-16 h-16 object-cover rounded"
                      />
                    </td>
                    <td class="px-6 py-4">
                      <p class="font-bold">{product.name}</p>
                      <p class="text-sm text-gray-500">{product.slug}</p>
                    </td>
                    <td class="px-6 py-4">{product.brand?.name || 'N/A'}</td>
                    <td class="px-6 py-4">{product.category?.name || 'N/A'}</td>
                    <td class="px-6 py-4">
                      <p class="font-bold">Q{product.price.toFixed(2)}</p>
                      {product.original_price && product.original_price > product.price && (
                        <p class="text-sm text-gray-400 line-through">Q{product.original_price.toFixed(2)}</p>
                      )}
                    </td>
                    <td class="px-6 py-4">
                      <span class={`px-3 py-1 rounded-full text-xs font-bold ${
                        product.stock > 10 ? 'bg-green-100 text-green-800' :
                        product.stock > 0 ? 'bg-yellow-100 text-yellow-800' :
                        'bg-red-100 text-red-800'
                      }`}>
                        {product.stock} unidades
                      </span>
                    </td>
                    <td class="px-6 py-4">
                      <span class={`px-3 py-1 rounded-full text-xs font-bold ${
                        product.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'
                      }`}>
                        {product.is_active ? 'Activo' : 'Inactivo'}
                      </span>
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex gap-2">
                        <button
                          class="edit-btn text-blue-600 hover:text-blue-800 font-bold flex items-center gap-1"
                          data-product={JSON.stringify(product)}
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                          </svg>
                          Editar
                        </button>
                        <button
                          class="delete-btn text-red-600 hover:text-red-800 font-bold flex items-center gap-1"
                          data-id={product.id}
                          data-name={product.name}
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                          </svg>
                          Eliminar
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Product Modal -->
  <div id="productModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-4xl w-full max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b flex justify-between items-center sticky top-0 bg-white">
        <h2 id="modalTitle" class="text-2xl font-bold">Nueva Fragancia</h2>
        <button id="closeModalBtn" class="text-gray-500 hover:text-black text-2xl">×</button>
      </div>

      <form id="productForm" class="p-6">
        <input type="hidden" id="productId" name="id" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Name -->
          <div class="md:col-span-2">
            <label for="name" class="block font-semibold mb-2">Nombre de la Fragancia *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="Ej: Lattafa Khamrah Dukhan"
            />
          </div>

          <!-- Slug -->
          <div class="md:col-span-2">
            <label for="slug" class="block font-semibold mb-2">Slug (URL) *</label>
            <input
              type="text"
              id="slug"
              name="slug"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="lattafa-khamrah-dukhan"
            />
            <p class="text-sm text-gray-500 mt-1">Se generará automáticamente del nombre</p>
          </div>

          <!-- Brand -->
          <div>
            <label for="brand_id" class="block font-semibold mb-2">Marca *</label>
            <select
              id="brand_id"
              name="brand_id"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
            >
              <option value="">Seleccionar marca</option>
              {allBrands.map((brand) => (
                <option value={brand.id}>{brand.name}</option>
              ))}
            </select>
          </div>

          <!-- Category -->
          <div>
            <label for="category_id" class="block font-semibold mb-2">Categoría *</label>
            <select
              id="category_id"
              name="category_id"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
            >
              <option value="">Seleccionar categoría</option>
              {allCategories.map((category) => (
                <option value={category.id}>{category.name}</option>
              ))}
            </select>
          </div>

          <!-- Price -->
          <div>
            <label for="price" class="block font-semibold mb-2">Precio (GTQ) *</label>
            <input
              type="number"
              id="price"
              name="price"
              required
              step="0.01"
              min="0"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="450.00"
            />
          </div>

          <!-- Original Price -->
          <div>
            <label for="original_price" class="block font-semibold mb-2">Precio Original (GTQ)</label>
            <input
              type="number"
              id="original_price"
              name="original_price"
              step="0.01"
              min="0"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="0.00"
            />
          </div>

          <!-- Stock -->
          <div>
            <label for="stock" class="block font-semibold mb-2">Stock *</label>
            <input
              type="number"
              id="stock"
              name="stock"
              required
              min="0"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="20"
            />
          </div>

          <!-- Image URL -->
          <div class="md:col-span-2">
            <label for="image_url" class="block font-semibold mb-2">URL de Imagen Principal *</label>
            <input
              type="text"
              id="image_url"
              name="image_url"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="/img/parfums/Men's/lattafa/Khamrah-Dukhan.webp"
            />
            <p class="text-sm text-gray-500 mt-1">Ruta de la imagen (ej: /img/parfums/...)</p>
          </div>

          <!-- Additional Images -->
          <div class="md:col-span-2">
            <label class="block font-semibold mb-2">Imágenes Adicionales (Máximo 5 imágenes en total)</label>
            <div id="imagesContainer" class="space-y-3">
              <!-- Image preview will be added here -->
            </div>
            <div class="mt-3">
              <label for="imageUpload" class="cursor-pointer inline-flex items-center px-4 py-2 border-2 border-dashed border-gray-300 rounded-lg hover:border-[#D4AF37] transition">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Agregar Imagen
              </label>
              <input
                type="file"
                id="imageUpload"
                accept="image/*"
                multiple
                class="hidden"
              />
              <p class="text-sm text-gray-500 mt-2">Puedes seleccionar múltiples imágenes. Formatos: JPG, PNG, WEBP</p>
            </div>
            <input type="hidden" id="images" name="images" value="[]" />
          </div>

          <!-- Sizes -->
          <div class="md:col-span-2">
            <label for="sizes" class="block font-bold mb-2">Tallas Disponibles *</label>
            <input
              type="text"
              id="sizes"
              name="sizes"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="100ml, 50ml, 30ml"
            />
            <p class="text-sm text-gray-500 mt-1">Tamaños disponibles, separar con comas</p>
          </div>

          <!-- Description -->
          <div class="md:col-span-2">
            <label for="description" class="block font-semibold mb-2">Descripción</label>
            <textarea
              id="description"
              name="description"
              rows="4"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#D4AF37]"
              placeholder="Descripción de la fragancia..."
            ></textarea>
          </div>

          <!-- Is Featured -->
          <div>
            <label class="flex items-center">
              <input
                type="checkbox"
                id="is_featured"
                name="is_featured"
                class="w-5 h-5 text-[#D4AF37] border-gray-300 rounded focus:ring-2 focus:ring-[#D4AF37]"
              />
              <span class="ml-2 font-semibold">Fragancia Destacada</span>
            </label>
          </div>

          <!-- Is Active -->
          <div>
            <label class="flex items-center">
              <input
                type="checkbox"
                id="is_active"
                name="is_active"
                checked
                class="w-5 h-5 text-[#D4AF37] border-gray-300 rounded focus:ring-2 focus:ring-[#D4AF37]"
              />
              <span class="ml-2 font-semibold">Fragancia Activa</span>
            </label>
          </div>
        </div>

        <div class="flex gap-4 mt-6">
          <button
            type="submit"
            class="flex-1 bg-[#D4AF37] text-black px-6 py-3 rounded-lg font-semibold hover:bg-[#C5A028] transition shadow-lg"
          >
            Guardar Fragancia
          </button>
          <button
            type="button"
            id="cancelBtn"
            class="px-6 py-3 border-2 border-black text-black rounded-lg font-semibold hover:bg-black hover:text-white transition"
          >
            Cancelar
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { sileo } from 'sileo';

    const modal = document.getElementById('productModal');
    const openModalBtn = document.getElementById('openModalBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const cancelBtn = document.getElementById('cancelBtn');
    const productForm = document.getElementById('productForm') as HTMLFormElement;
    const modalTitle = document.getElementById('modalTitle');
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;
    const imageUpload = document.getElementById('imageUpload') as HTMLInputElement;
    const imagesContainer = document.getElementById('imagesContainer');
    const imagesHidden = document.getElementById('images') as HTMLInputElement;

    let uploadedImages: string[] = [];
    const MAX_IMAGES = 5;

    // Auto-generate slug from name
    nameInput?.addEventListener('input', () => {
      const slug = nameInput.value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      if (slugInput) slugInput.value = slug;
    });

    // Handle image upload
    imageUpload?.addEventListener('change', (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (!files) return;

      const remainingSlots = MAX_IMAGES - uploadedImages.length;
      if (files.length > remainingSlots) {
        sileo.warning({ description: `Solo puedes agregar ${remainingSlots} imagen(es) más. Máximo ${MAX_IMAGES} imágenes por producto.` });
        return;
      }

      Array.from(files).forEach((file) => {
        if (uploadedImages.length >= MAX_IMAGES) {
          sileo.warning({ description: `Máximo ${MAX_IMAGES} imágenes por producto` });
          return;
        }

        const reader = new FileReader();
        reader.onload = (event) => {
          const imageUrl = event.target?.result as string;
          uploadedImages.push(imageUrl);
          updateImagesDisplay();
          updateImagesHidden();
        };
        reader.readAsDataURL(file);
      });

      // Reset input
      imageUpload.value = '';
    });

    function updateImagesDisplay() {
      if (!imagesContainer) return;
      
      // Ensure uploadedImages is an array
      if (!Array.isArray(uploadedImages)) {
        uploadedImages = [];
      }
      
      imagesContainer.innerHTML = uploadedImages.map((img, index) => `
        <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg">
          <img src="${img}" alt="Imagen ${index + 1}" class="w-20 h-20 object-cover rounded" />
          <div class="flex-1">
            <p class="text-sm font-semibold">Imagen ${index + 1}</p>
            <p class="text-xs text-gray-500">${index === 0 ? 'Imagen principal' : 'Imagen adicional'}</p>
          </div>
          <button
            type="button"
            onclick="removeImage(${index})"
            class="text-red-600 hover:text-red-800 p-2"
            aria-label="Eliminar imagen ${index + 1}"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      `).join('');
    }

    function updateImagesHidden() {
      if (imagesHidden) {
        imagesHidden.value = JSON.stringify(uploadedImages);
      }
    }

    // Make removeImage available globally
    (window as any).removeImage = (index: number) => {
      uploadedImages.splice(index, 1);
      updateImagesDisplay();
      updateImagesHidden();
      sileo.success({ description: 'Imagen eliminada' });
    };

    // Open modal for new product
    openModalBtn?.addEventListener('click', () => {
      if (modalTitle) modalTitle.textContent = 'Nueva Fragancia';
      productForm?.reset();
      (document.getElementById('productId') as HTMLInputElement).value = '';
      (document.getElementById('is_active') as HTMLInputElement).checked = true;
      uploadedImages = [];
      updateImagesDisplay();
      updateImagesHidden();
      modal?.classList.remove('hidden');
    });

    // Close modal
    const closeModal = () => {
      modal?.classList.add('hidden');
      productForm?.reset();
      uploadedImages = [];
      updateImagesDisplay();
      updateImagesHidden();
    };

    closeModalBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);

    // Close modal on outside click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Edit product
    document.querySelectorAll('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const productData = btn.getAttribute('data-product');
        if (!productData) return;

        const product = JSON.parse(productData);
        if (modalTitle) modalTitle.textContent = 'Editar Fragancia';

        // Fill form
        (document.getElementById('productId') as HTMLInputElement).value = product.id;
        (document.getElementById('name') as HTMLInputElement).value = product.name;
        (document.getElementById('slug') as HTMLInputElement).value = product.slug;
        (document.getElementById('brand_id') as HTMLSelectElement).value = product.brand_id;
        (document.getElementById('category_id') as HTMLSelectElement).value = product.category_id;
        (document.getElementById('price') as HTMLInputElement).value = product.price;
        (document.getElementById('original_price') as HTMLInputElement).value = product.original_price || '';
        (document.getElementById('stock') as HTMLInputElement).value = product.stock;
        (document.getElementById('image_url') as HTMLInputElement).value = product.image_url;
        (document.getElementById('sizes') as HTMLInputElement).value = product.sizes.join(', ');
        (document.getElementById('description') as HTMLTextAreaElement).value = product.description || '';
        (document.getElementById('is_featured') as HTMLInputElement).checked = product.is_featured === 1;
        (document.getElementById('is_active') as HTMLInputElement).checked = product.is_active === 1;

        // Load existing images
        try {
          if (product.images) {
            if (typeof product.images === 'string') {
              uploadedImages = JSON.parse(product.images);
            } else if (Array.isArray(product.images)) {
              uploadedImages = product.images;
            } else {
              uploadedImages = [];
            }
          } else {
            uploadedImages = [];
          }
        } catch (e) {
          console.error('Error parsing images:', e);
          uploadedImages = [];
        }
        updateImagesDisplay();
        updateImagesHidden();

        modal?.classList.remove('hidden');
      });
    });

    // Submit form
    productForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(productForm);
      const productId = formData.get('id');
      const isEdit = !!productId;

      const data = {
        id: productId ? parseInt(productId as string) : undefined,
        name: formData.get('name'),
        slug: formData.get('slug'),
        brand_id: parseInt(formData.get('brand_id') as string),
        category_id: parseInt(formData.get('category_id') as string),
        price: parseFloat(formData.get('price') as string),
        original_price: formData.get('original_price') ? parseFloat(formData.get('original_price') as string) : null,
        stock: parseInt(formData.get('stock') as string),
        image_url: formData.get('image_url'),
        sizes: (formData.get('sizes') as string).split(',').map(s => s.trim()),
        images: uploadedImages.length > 0 ? uploadedImages : [],
        description: formData.get('description') || null,
        is_featured: formData.get('is_featured') ? 1 : 0,
        is_active: formData.get('is_active') ? 1 : 0,
      };

      try {
        const response = await fetch('/api/shoes', {
          method: isEdit ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          sileo.success({ description: isEdit ? 'Fragancia actualizada exitosamente' : 'Fragancia creada exitosamente' });
          setTimeout(() => window.location.reload(), 1500);
        } else {
          const error = await response.json();
          sileo.error({ description: error.error || 'Error al guardar la fragancia' });
        }
      } catch (error) {
        console.error('Error:', error);
        sileo.error({ description: 'Error de conexión' });
      }
    });

    // Delete product
    document.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');

        sileo.action({
          title: 'Confirmar eliminación',
          description: `¿Estás seguro de eliminar "${name}"?`,
          duration: null,
          button: {
            title: 'Eliminar',
            onClick: async () => {
              try {
                const response = await fetch(`/api/shoes/${id}`, {
                  method: 'DELETE',
                });

                if (response.ok) {
                  sileo.success({ description: 'Fragancia eliminada exitosamente' });
                  setTimeout(() => window.location.reload(), 1500);
                } else {
                  const error = await response.json();
                  sileo.error({ description: error.error || 'Error al eliminar la fragancia' });
                }
              } catch (error) {
                console.error('Error:', error);
                sileo.error({ description: 'Error de conexión' });
              }
            }
          }
        });
      });
    });

    // Handle logout
    const logoutForm = document.querySelector('form[action="/api/auth/logout"]');
    if (logoutForm) {
      logoutForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        try {
          const response = await fetch('/api/auth/logout', {
            method: 'POST',
          });
          
          if (response.ok) {
            window.location.href = '/login';
          }
        } catch (error) {
          console.error('Logout error:', error);
        }
      });
    }
  </script>
</body>
</html>
