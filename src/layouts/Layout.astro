---
import '../styles/global.css';
import 'sileo/styles.css';
import CartButton from '../components/react/CartButton';
import { Toaster } from 'sileo';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AV Parfums - Fragancias de lujo en Guatemala' } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    
    <!-- Preload critical assets -->
    <link rel="preload" href="/new-logo.png" as="image" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" as="style" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon 256x256.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/new-logo.png" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Elegant Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Skip to main content for accessibility -->
    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #D4AF37;
        color: #000;
        padding: 8px 16px;
        text-decoration: none;
        font-weight: bold;
        z-index: 100;
      }
      .skip-link:focus {
        top: 0;
      }
      
      /* Custom font families */
      .font-display {
        font-family: 'Playfair Display', serif;
      }
      
      .font-body {
        font-family: 'Inter', sans-serif;
      }
    </style>
  </head>
  <body class="font-body antialiased bg-white text-gray-900">
    <!-- Skip to main content link -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    
    <!-- Sileo Toast Notifications -->
    <Toaster client:load position="top-right" offset={{ top: "5rem" }} options={{ fill: "#000000" }} />
    
    <!-- Topbar -->
    <div class="bg-white text-black text-center py-2.5 text-sm font-medium tracking-wide border-b border-gray-200" role="banner" aria-label="Promoción de envío gratis">
      <p class="flex items-center justify-center gap-2">
        <svg class="w-4 h-4 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
        <span>Envío gratis en compras mayores a <span class="text-[#D4AF37] font-semibold">Q500</span></span>
      </p>
    </div>
    
    <!-- Header -->
    <header class="bg-black text-white sticky top-0 z-50 shadow-lg" role="banner">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded" aria-label="AV Parfums - Ir a la página de inicio">
            <img src="/new-logo.png" alt="AV Parfums Logo" class="h-12" width="150" height="48" />
          </a>
          
          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center space-x-8 font-medium" role="navigation" aria-label="Navegación principal">
            <a href="/" class="text-white hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded px-2 py-1" aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>Inicio</a>
            <a href="/catalog" class="text-white hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded px-2 py-1" aria-current={Astro.url.pathname === '/catalog' ? 'page' : undefined}>Catálogo</a>
            <a href="/catalog?featured=true" class="text-white hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded px-2 py-1">Destacados</a>
            <a href="/contact" class="text-white hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded px-2 py-1">Contacto</a>
          </nav>
          
          <!-- Actions -->
          <div class="flex items-center space-x-4">
            <CartButton client:load />
            <a href="/login" class="text-white hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded p-1" aria-label="Iniciar sesión">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </header>
    
    <!-- Main Content -->
    <main id="main-content" role="main">
      <slot />
    </main>
    
    <!-- Footer -->
    <footer class="bg-black text-white mt-20" role="contentinfo">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Logo & Description -->
          <div class="col-span-1 md:col-span-2">
            <img src="/new-logo.png" alt="AV Parfums Logo" class="h-12 mb-4 brightness-0 invert" width="150" height="48" />
            <p class="text-gray-300 mb-4 leading-relaxed">
              Fragancias de lujo en Guatemala. Descubre nuestra exclusiva colección de perfumes de las mejores marcas internacionales.
            </p>
          </div>
          
          <!-- Quick Links -->
          <nav aria-label="Enlaces rápidos del pie de página">
            <h3 class="font-semibold mb-4 text-[#D4AF37]">Enlaces Rápidos</h3>
            <ul class="space-y-2 text-gray-300">
              <li><a href="/catalog" class="hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded">Catálogo</a></li>
              <li><a href="/catalog?featured=true" class="hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded">Destacados</a></li>
              <li><a href="/contact" class="hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded">Contacto</a></li>
            </ul>
          </nav>
          
          <!-- Contact -->
          <div>
            <h3 class="font-semibold mb-4 text-[#D4AF37]">Contacto</h3>
            <ul class="space-y-2 text-gray-300">
              <li><a href="mailto:info@avparfums.com" class="hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded" aria-label="Enviar correo a info@avparfums.com">📧 info@avparfums.com</a></li>
              <li><a href="tel:+50212345678" class="hover:text-[#D4AF37] transition focus:outline-none focus:ring-2 focus:ring-[#D4AF37] rounded" aria-label="Llamar al +502 1234-5678">📱 +502 1234-5678</a></li>
              <li>📍 Guatemala, GT</li>
            </ul>
          </div>
        </div>
        
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
          <p>&copy; {new Date().getFullYear()} AV Parfums. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
